 Adapted for the mjlab robot-safety-sandbox car_goal task: a differential-drive
 car (free-joint box chassis + 2 hinge wheels + a passive ball caster). The
 standalone floor, cameras, sensors and <motor> actuators from the original
 safety-gymnasium asset are removed here -- mjlab supplies the ground (terrain),
 the observations, and the wheel <velocity> actuators (see car_constants.py).
-->

<mujoco model="car">
  <default>
    <geom condim="6" density="5" size=".05" type="sphere"/>
    <joint damping=".001"/>
  </default>
  <worldbody>
    <body name="agent" pos="0 0 .1">
      <joint type="free" name="agent" damping="0"/>
      <geom name="chassis" type="box" size=".1 .1 .05" rgba="0.7412 0.0431 0.1843 1"/>
      <geom name="back_bumper" type="box" pos="0 .15 0" size=".1 .01 .05" rgba="0.0039 0.1529 0.3961 1"/>
      <geom name="back_connector" type="box" pos="0 .125 0" size=".01 .025 .03" rgba="0.0039 0.1529 0.3961 1"/>
      <geom name="front_bumper" type="box" pos="0 -.165 0" size=".05 .01 .05" rgba="0.0039 0.1529 0.3961 1"/>
      <geom name="front_connector" type="box" pos="0 -.13 .04" size=".05 .03 .01" rgba="0.0039 0.1529 0.3961 1"/>
      <body name="left" pos="-.1 .1 -.05">
        <joint type="hinge" name="left" axis="1 0 0"/>
        <geom type="cylinder" name="left" fromto="-.055 0 0 -0.005 0 0" rgba="0.7412 0.0431 0.1843 1"/>
      </body>
      <body name="right" pos=".1 .1 -.05">
        <joint type="hinge" name="right" axis="1 0 0"/>
        <geom type="cylinder" name="right" fromto="0.005 0 0 .055 0 0" rgba="0.7412 0.0431 0.1843 1"/>
      </body>
      <body name="rear" pos="0 -.1 -.05">
        <joint name="rear" type="ball"/>
        <geom name="rear" rgba="0.7412 0.0431 0.1843 1"/>
      </body>
    </body>
  </worldbody>
</mujoco>
